{
    "name": "ne-rewritten",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "build:singlefile": "vue-tsc -b && vite build --config vite.singlefile.config.js && node -e \"require('fs').renameSync('dist/index.html','dist/NE-rewritten.html')\"",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@codemirror/basic-setup": "^0.20.0",
        "@codemirror/lang-javascript": "^6.2.5",
        "codemirror": "^6.0.2",
        "katex": "^0.17.0",
        "marked": "^18.0.6",
        "vue": "^3.5.34"
    },
    "devDependencies": {
        "@types/marked": "^5.0.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "exceljs": "^3.4.0",
        "prettier": "3.9.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vite-plugin-singlefile": "^2.3.3",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.5"
    },
    "overrides": {
        "uuid": ">=11.1.1"
    }
}
